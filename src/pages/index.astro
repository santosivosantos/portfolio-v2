---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projects = [
  {
    title: "BMW C Evolution",
    subtitle: "Electric Motorcycle Instrument Cluster",
    year: "2012 — 2014",
    tags: ["Automotive", "Safety-Critical", "HMI"],
    url: `${base}/case-studies/bmw-c-evolution/`
  },
  {
    title: "EMS Dashboard",
    subtitle: "Energy Management System",
    year: "2025 — 2026",
    tags: ["B2B", "Data Visualization", "Industrial"],
    url: `${base}/case-studies/ems-dashboard/`
  }
];
---

<Layout>
  <main>
    <header>
      <p class="label">UX/UI Designer — 10+ Years</p>
      <h1>Ivo Santos</h1>
      <p class="lead">
        I design interfaces for complex systems. Currently leading the EMS prototype
        at Phoenix Contact. Previously shipped the instrument cluster for BMW Motorrad's
        first electric vehicle.
      </p>
      <a href="mailto:hi@ivosantos.com" class="cta">hi@ivosantos.com</a>
    </header>

    <section class="projects">
      <p class="section-label">Selected Work</p>
      <div class="project-grid">
        {projects.map(p => (
          <a href={p.url} class="project-card">
            <span class="project-year">{p.year}</span>
            <h3>{p.title}</h3>
            <p class="project-subtitle">{p.subtitle}</p>
            <div class="project-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="clients">
      <p class="section-label">Selected Clients</p>
      <div class="logo-row">
        <div class="logo-item">
          <img src={`${base}/images/logos/bmw-group.svg`} alt="BMW Group" />
        </div>
        <div class="logo-item">
          <img src={`${base}/images/logos/bmw-motorrad.svg`} alt="BMW Motorrad" />
        </div>
        <div class="logo-item">
          <img src={`${base}/images/logos/mini.svg`} alt="MINI" />
        </div>
        <div class="logo-item">
          <img src={`${base}/images/logos/john-deere.svg`} alt="John Deere" />
        </div>
        <div class="logo-item">
          <img src={`${base}/images/logos/avatera-medical.svg`} alt="Avatera Medical" />
        </div>
        <div class="logo-item">
          <img src={`${base}/images/logos/crossmatch.svg`} alt="Crossmatch" />
        </div>
      </div>
    </section>

    <footer>
      <p>Designed and built with Astro.</p>
    </footer>
  </main>
</Layout>
